.banner-cta-container{display:flex;/*justify-content:space-between*/}
.banner-cta-button1{background-color:var(--accent);color:#000;display:inline-flex;column-gap:10px;padding:10px;border-radius:30px;font-weight:500;align-items: center;transition:.5s all;position:relative}

.banner-cta-button2{color:#fff;display:inline-flex;column-gap:10px;padding:10px;border-radius:30px;font-weight:500;align-items: center;transition:.5s all;opacity:0.9}
	
.banner-cta-button3{background-color:var(--accent);color:#000;display:inline-flex;column-gap:10px;padding:10px;border-radius:30px;font-weight:500;align-items: center;transition:.5s all;opacity:0.7;transform: translate(0px, 0px)}

.banner-cta-button4{color:#000;display:inline-flex;column-gap:10px;padding:10px;border:1px solid #000;border-radius:30px;font-weight:500;align-items: center;transition:.5s all;opacity:0.7;transform: translate(0px, 0px)}
	
.banner-cta-button5{color:#cb0000;display:inline-flex;column-gap:10px;padding:5px;border:1px solid #c2c2c2;border-radius:33px;font-weight:500;align-items: center;transition:.5s all;opacity:0.7;transform: translate(0px, 0px);min-width: 220px;}
.cta-button-text5{padding:12px 50px 12px 5px;letter-spacing:2px;font-size:12.9px}
.banner-cta-button5:hover{padding:5px 9px;opacity:1!important}
.banner-cta-button5 img{transition:0.5s all;position:absolute;right:7px;opacity:0.2}
.banner-cta-button5:hover img{width:43px;height:43px}

.banner-cta-button-white{color:#fff;display:inline-flex;column-gap:10px;padding:10px;/*border:1px solid #fff;*/border-radius:30px;font-weight:500;align-items: center;transition:.5s all;opacity:0.7;transform: translate(0px, 0px)}

.banner-cta-button1:hover,.banner-cta-button2:hover,.banner-cta-button3:hover,.banner-cta-button4:hover,.banner-cta-button-white:hover{padding:10px 14px;opacity:1!important}
.banner-cta-button1 img,.banner-cta-button2 img,.banner-cta-button3 img,.banner-cta-button4 img,.banner-cta-button-white img{transition:0.5s all;position:absolute;right:10px}
.banner-cta-button1:hover img,.banner-cta-button2:hover img,.banner-cta-button3:hover img,.banner-cta-button4:hover img,.banner-cta-button-white:hover img{width:45px;height:45px}
.cta-button-text{padding:10px 65px 10px 45px;letter-spacing:2px;font-size:12px}

