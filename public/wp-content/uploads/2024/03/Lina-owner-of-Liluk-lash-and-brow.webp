<script>



/*
==================================================
ANIMATION CLASSES – SHORT EXPLANATION
==================================================

.text-reveal1-title
  Word-by-word reveal for main headings. Words fade in and rise slightly.

.text-reveal1-subtitle
  Same as above but starts a bit later. Used for subtitles under the title.

.image-float
  Image fades in and slides up, then gently floats based on scroll speed.

.kb-buttons-wrap
  Button groups fade in and slide up with a soft bump (Kadence auto class).

.img-appear
  Normal image reveal. The <img> inside zooms from 1.1 to 1 and fades in.

.img-appear-fade-parallax
  Background section fades in early and background moves slightly for parallax.
  
  .img-appear-section
  Same but for section

.img-appear-hero
  Hero row fades in on load and background animates with parallax on scroll.

.img-appear-fade
  Simple fade-in of the whole background section, no movement.

.img-appear-parallax
  Background-only parallax. Moves background position on scroll, no fade.

.img-appear-filter
  Unblurs and brightens a background (from blur/dim to normal).

.img-appear-scale
  Background zoom-out on scroll (background-size from 110% to 100%).

.no-html-needed (INFO)
  All <p> and <li> inside .kt-inside-inner-col fade+slide in automatically.
*/






// register GSAP plugins at the very top so they are ready for all code below
gsap.registerPlugin(ScrollTrigger,SplitText);

// run everything after full page load (safer for Kadence, images, fonts)
window.addEventListener("load",function(){
    
   
   
   
   
   
   
// COLUMN ZOOM+FADE + INNER PARALLAX
gsap.utils.toArray(".img-appear-section3").forEach(function(col){

  var row = col.closest(".kb-row-layout-wrap");              // parent row (if exists)
  var inner = col.querySelector(".kt-inside-inner-col");     // inner with pseudo bg
  if(!inner){return;}

  // make sure inner is visible (Kadence may set opacity:0)
  gsap.set(inner,{opacity:1});

  // 1) COLUMN ZOOM + FADE (like .img-appear, but on whole column)
  gsap.fromTo(
    col,
    {scale:1.1,opacity:0},
    {
      scrollTrigger:{
        trigger:col,
        start:"top 80%",
        toggleActions:"play none none reset"
      },
      scale:1,
      opacity:1,
      duration:1,
      ease:"power2.out"
    }
  );

  // 2) PARALLAX ON PSEUDO BACKGROUND (via --parallaxY)
  gsap.fromTo(
    inner,
    {"--parallaxY":"10%"},
    {
      "--parallaxY":"-10%",
      scrollTrigger:{
        trigger:row || col,
        start:"top bottom",
        end:"bottom top",
        scrub:1
      },
      ease:"none"
    }
  );

});

   
   
   
   
   
   
   
   
// BG FADE + PARALLAX FOR SECTION COLUMN (.img-appear-section ON COLUMN) simple appear effect no paralax
gsap.utils.toArray(".img-appear-section").forEach(function(col){

  var row = col.closest(".kb-row-layout-wrap");

  // fade can still target both (row + column)
  var fadeTargets = row && row !== col ? [row, col] : [col];

  // 1) FADE
  gsap.fromTo(
    fadeTargets,
    { opacity: 0 },
    {
      opacity: 1,
      scrollTrigger: {
        trigger: row || col,
        start: "top 95%",
        end: "top 55%",
        scrub: true
      },
      duration: 0.5,
      ease: "power1.out"
    }
  );

  // 2) PARALLAX – only the column that actually has the background
gsap.fromTo(
  col,
  { y: 0 },
  {
    y: 150,
    scrollTrigger: {
      trigger: row || col,
      start: "top bottom",
      end: "bottom top",
      scrub: 1
    },
    ease: "none"
  }
);


});

   
   
   
   
   
  //moving paralax inside with image size increase
   
   
gsap.utils.toArray(".img-appear-section2").forEach(function(col){

  // row wrapper for nicer trigger behaviour
  var row = col.closest(".kb-row-layout-wrap");

  // inner element that holds the pseudo background
  var inner = col.querySelector(".kt-inside-inner-col");
  if (!inner) return; // safety

  // fade whole section: row + column when row exists, otherwise column only
  var fadeTargets = row && row !== col ? [row, col] : [col];

  // 1) FADE IN
  gsap.fromTo(
    fadeTargets,
    { opacity: 0 },
    {
      opacity: 1,
      scrollTrigger: {
        trigger: row || col,
        start: "top 80%",   // start just before entering view
        end: "top 50%",     // finish quickly reduce to increase gap and make longer
        scrub: true
      },
      duration: 0.5,
      ease: "power1.out"
    }
  );

  // 2) PARALLAX ON PSEUDO BACKGROUND (via CSS variable)
  gsap.fromTo(
    inner,
    { "--parallaxY": "10%" },
    {
      "--parallaxY": "-10%",
      scrollTrigger: {
        trigger: row || col,
        start: "top bottom",
        end: "bottom top",
        scrub: 1
      },
      ease: "none"
    }
  );

});


   
   
   
   
   
   
   
   
   
   
   
   
   
   
   
   
   
    
    
  
  
  
document.fonts.ready.then(function () {

  function createWordReveal(selector, extraDelay) {

    document.querySelectorAll(selector).forEach(function (el) {

      ScrollTrigger.create({
        trigger: el,
        start: "top 85%",
        once: true,
        onEnter: function () {

          var split = new SplitText(el, { type: "words", tag: "span" });

          // Hide only the split words immediately.
          gsap.set(split.words, { opacity: 0, y: 20 });

          gsap.to(split.words, {
            opacity: 1,
            y: 0,
            duration: 1.1,
            ease: "sine.out",
            stagger: 0.1,
            delay: extraDelay,
            onComplete: function () {
              gsap.set(split.words, { clearProps: "opacity,transform,will-change" });
              split.revert();
            }
          });

        }
      });

    });

  }

  createWordReveal(".text-reveal1-title", 0);
  createWordReveal(".text-reveal1-subtitle", 0.9);

});

    
    
  // ============================
  // 1. FLOATING IMAGE EFFECT
  // ============================

  // simple fade + slide in for all .image-float elements
  gsap.utils.toArray(".image-float").forEach(function(item){          // loop through each .image-float
    gsap.from(item,{                                                  // animate from the initial state
      opacity:0,                                                      // start fully transparent
      y:160,                                                          // start 160px lower
      duration:1.4,                                                   // animation time in seconds
      ease:"power3.out",                                              // easing curve, smooth and punchy
      scrollTrigger:{                                                 // attach ScrollTrigger to this tween
        trigger:item,                                                 // use this element as the trigger
        start:"top 85%",                                              // start when top reaches 85% viewport height
        toggleActions:"play none none none"                           // play once, no reverse on scroll back
      }
    });
  });

  // floating behaviour based on scroll velocity (optional fancy part)
  var maxOffset=120;                                                  // maximum Y offset allowed for the float
  var currentY=0;                                                     // current Y offset
  var lerpToY=gsap.quickTo(".image-float","y",{                       // helper that smoothly animates all .image-float y
    duration:1.8,                                                     // how slow the follow effect is
    ease:"power3.out"                                                 // easing for the follow
  });

  ScrollTrigger.create({                                              // create one ScrollTrigger for the floating logic
    trigger:".image-float",                                           // any .image-float on the page
    start:"top bottom",                                               // when top of first image enters bottom of viewport
    end:"bottom top",                                                 // until last image leaves top of viewport
    onUpdate:function(self){                                          // called on each scroll update
      var v=self.getVelocity();                                       // current scroll velocity
      var delta=v*0.22/100;                                          // convert velocity to a usable offset (0.22 = strength)
      currentY+=delta;                                                // accumulate offset
      currentY=gsap.utils.clamp(-maxOffset,maxOffset,currentY);       // clamp between -maxOffset and +maxOffset
      lerpToY(currentY);                                              // smoothly animate images to new Y
    }
  });

  // ============================
  // 2. BUTTON REVEAL
  // ============================

  gsap.utils.toArray(".kb-buttons-wrap").forEach(function (group) {

  ScrollTrigger.create({
    trigger: group,
    start: "top 85%",
    once: true,
    onEnter: function () {

      // Make visible only when we are ready to animate (prevents flash/jump).
      group.classList.add("is-gsap-ready");

      gsap.fromTo(
        group,
        { opacity: 0, y: 40 },
        {
          opacity: 1,
          y: 0,
          duration: 0.9,
          ease: "back.out(1.4)",
          delay: 0.25,

          // Remove inline styles GSAP added, so markup stays clean after.
          onComplete: function () {
            gsap.set(group, { clearProps: "opacity,transform" });
          }
        }
      );

    }
  });

});


  // ============================
  // 3. NORMAL IMG REVEAL (WRAPPED IMAGES)
  //    expects: <div class="img-appear"><img ...></div>
  // ============================

  gsap.utils.toArray(".img-appear").forEach(function(wrapper){        // loop through all .img-appear wrappers
    var img=wrapper.querySelector("img");                             // find the img inside
    if(!img){return;}                                                 // if no img, skip this wrapper

    gsap.fromTo(img,                                                  // animate the image itself
      {scale:1.1,opacity:0},                                          // start slightly zoomed in and invisible
      {
        scrollTrigger:{                                               // add ScrollTrigger
          trigger:wrapper,                                            // use wrapper as trigger
          start:"top 80%",                                            // start when wrapper reaches 80% viewport height
          toggleActions:"play reverse play reverse"                   // play in, reverse out
        },
        scale:1,                                                      // end at normal size
        opacity:1,                                                    // end fully visible
        duration:1,                                                   // animation duration
        ease:"power2.out"                                             // smooth ease
      }
    );
  });

  // ============================
  // 4. BG FADE + PARALLAX (HERO, MAIN ROWS)
  //    class: .img-appear-fade-parallax on Kadence row
  // ============================

gsap.utils.toArray(".img-appear-fade-parallax").forEach(function(item){

  // 1) FADE ONLY – short scroll range so opacity hits 1 early
  gsap.fromTo(
    item,
    {
      opacity:0                      // start almost visible (0 = fully invisible)
    },
    {
      opacity:1,                       // reach full opacity quickly
      scrollTrigger:{
        trigger:item,                  // this row controls its own fade
        // when fade starts
        // bigger second value (95–100%) = fade starts earlier
        start:"top 95%",
        // when fade finishes
        // closer to start = shorter fade distance
        // here: when top moves from 95% down to 75%
        end:"top 55%",
        scrub:true                     // keep fade tied to scroll in this short range
      },
      duration:0.5,                    // generic, scrub dominates but keep it short
      ease:"power1.out"                // simple, not too dramatic
    }
  );

  // 2) PARALLAX ONLY – can use a longer scroll range
  gsap.fromTo(
    item,
    {
      backgroundPosition:"center 80%"  // starting background position (lower image)
    },
    {
      backgroundPosition:"center 60%", // end position (image moves up)
      scrollTrigger:{
        trigger:item,                  // same row
        // start moving background at same time as fade (or change if you want)
        start:"top 95%",
        // keep moving until the row scrolls out
        end:"bottom top",
        scrub:1                        // smooth parallax; higher = smoother
      },
      ease:"power2.out"
    }
  );

});


  
  
  
  
  
  
  
  

  // ============================
  // 5. TEST / ALT BG EFFECTS
  //    each class controls one effect type, no overlap
  // ============================

  // 5a. Simple fade-in bg (no parallax)
  gsap.utils.toArray(".img-appear-fade").forEach(function(item){      // loop fade-only rows
    gsap.to(item,{                                                    // animate to final state
      scrollTrigger:{                                                 // add ScrollTrigger
        trigger:item,                                                 // each row triggers itself
        start:"top 80%",                                              // start when row top at 80%
        toggleActions:"play reverse play reverse"                     // play in, reverse out
      },
      opacity:1,                                                      // end fully visible
      duration:1,                                                     // duration
      ease:"power2.out"                                               // ease curve
    });
  });

  // 5b. Parallax-only bg movement
  gsap.utils.toArray(".img-appear-parallax").forEach(function(item){  // loop parallax-only rows
    gsap.fromTo(item,                                                 // animate bg position only
      {backgroundPosition:"center 75%"},                              // start position
      {
        scrollTrigger:{                                               // ScrollTrigger config
          trigger:item,                                               // this row is its trigger
          start:"top 80%",                                            // start point
          toggleActions:"play reverse play reverse"                   // play and reverse on enter/leave
        },
        backgroundPosition:"center 65%",                              // end position (adjust for strength)
        duration:1.2,                                                 // duration
        ease:"power2.out"                                             // easing
      }
    );
  });

  // 5c. Filter reveal (brightness + blur)
  gsap.utils.toArray(".img-appear-filter").forEach(function(item){    // loop filter rows
    gsap.to(item,{                                                    // animate filter to clear state
      scrollTrigger:{                                                 // ScrollTrigger
        trigger:item,                                                 // this row as trigger
        start:"top 80%",                                              // when to start
        toggleActions:"play reverse play reverse"                     // play / reverse
      },
      filter:"brightness(1) blur(0px)",                               // final filter (normal brightness, no blur)
      duration:1.2,                                                   // duration
      ease:"power2.out"                                               // easing
    });
  });

  // 5d. Background-size scale (zoom-out effect)
  gsap.utils.toArray(".img-appear-scale").forEach(function(item){     // loop scale rows
    gsap.to(item,{                                                    // animate background-size
      scrollTrigger:{                                                 // ScrollTrigger
        trigger:item,                                                 // this row as trigger
        start:"top 80%",                                              // start point
        toggleActions:"play reverse play reverse"                     // play / reverse
      },
      backgroundSize:"100%",                                          // final size (start from 110% in CSS)
      duration:1.2,                                                   // duration
      ease:"power2.out"                                               // easing
    });
  });

});



	
	
	
	

</script>




		
</body>
