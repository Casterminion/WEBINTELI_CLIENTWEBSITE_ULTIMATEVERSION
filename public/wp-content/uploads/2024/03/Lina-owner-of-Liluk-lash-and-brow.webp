<header>


	
<div class="top-logo">
	<a href="https://webdesigner.london" title="Web Designer London"><span id="title">&laquo;Web Designer&raquo;</span></a>

    <script>
        let hasDeleted = false; // Track whether deletion has already occurred

        window.addEventListener("scroll", function() {
            const title = document.getElementById('title');
            const fullText = "«Web Designer»";
            const singleText = "«W»";

            if (window.scrollY > 200 && !hasDeleted) {
                hasDeleted = true; // Mark as deleted so it runs only once
                let index = fullText.length;

                // Delete each letter one by one
                const deleteLetter = () => {
                    if (index > 1) {
                        title.textContent = fullText.substring(0, index - 1);
                        index--;
                        setTimeout(deleteLetter, 100);
                    } else {
                        title.textContent = singleText;
                    }
                };
                deleteLetter();
            } else if (window.scrollY <= 200 && hasDeleted) {
                hasDeleted = false; // Allow reset when scrolling back up

                // Add each letter one by one to simulate typing
                let index = 1;

                const typeLetter = () => {
                    if (index <= fullText.length) {
                        title.textContent = fullText.substring(0, index);
                        index++;
                        setTimeout(typeLetter, 100);
                    }
                };
                typeLetter();
            }
        });
    </script>

</div>

	
	
	
	
	
	
	
