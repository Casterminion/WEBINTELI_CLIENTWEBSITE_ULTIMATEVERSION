.text-right{text-align:right}
.screen-reader-text {border: 0;clip: rect(0 0 0 0);height: 1px;margin: -1px;overflow: hidden;padding: 0;position: absolute;width: 1px;white-space: nowrap;}
:root {--menu:#000;--primary: #1277A6;--accent:#ff9800}
.opacity{opacity:0.7}
.menu-item,.opacity-hover{transition:0.5s opacity;opacity:.7}
.opacity-hover:hover,.menu-item:hover{opacity:1}
