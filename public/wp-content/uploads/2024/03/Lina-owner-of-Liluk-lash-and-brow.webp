<script>
document.addEventListener("DOMContentLoaded", function() {
  // Observer for scroll-up elements
  const scrollUpObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('on-screen');
      } else {
        entry.target.classList.remove('on-screen');
      }
    });
  }, {
    rootMargin: '200px 0px 0px 0px',
    threshold: 0.4
  });

  // Observer for scroll-up-image elements
  const scrollUpImageObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('on-screen');
      } else {
        entry.target.classList.remove('on-screen');
      }
    });
  }, {
    rootMargin: '600px 0px 0px 0px',
    threshold: 0.2
  });

  // Select all elements that need the scroll-up observer
  const scrollUpElements = document.querySelectorAll('.scroll-up');
  scrollUpElements.forEach(el => scrollUpObserver.observe(el));

  // Select all elements that need the scroll-up-image observer
  const scrollUpImageElements = document.querySelectorAll('.scroll-up-image');
  scrollUpImageElements.forEach(el => scrollUpImageObserver.observe(el));
});
</script>

	
	

