<style id="kadence_blocks_palette_css">:root .has-kb-palette-1-color{color:#ffffff}:root .has-kb-palette-1-background-color{background-color:#ffffff}:root .has-kb-palette-2-color{color:#000000}:root .has-kb-palette-2-background-color{background-color:#000000}:root .has-kb-palette-22-color{color:#f2f2f2}:root .has-kb-palette-22-background-color{background-color:#f2f2f2}:root .has-kb-palette-3-color{color:#ff9800}:root .has-kb-palette-3-background-color{background-color:#ff9800}:root .has-kb-palette-4-color{color:#cc7900}:root .has-kb-palette-4-background-color{background-color:#cc7900}</style><style>

/* latin */
@font-face {
  font-family: 'Outfit';
  font-style: normal;
  font-weight: 100 900;
  font-display: optional;
  src: url(https://webdesigner.london/wp-content/themes/webdesignerlondon/fonts/out.woff2) format('woff2');
}


/* general */
html {height:100%;scroll-behavior: smooth;}
body {font-family: "Outfit", sans-serif;font-weight: 300;font-size:16px;line-height:1.4;color:#000;background-color:#fff;margin: 0;}
p{color:inherit;margin:10px 0;opacity:.9}
h1, h2, h3, h4 {font-family: "Outfit", sans-serif;margin:0;line-height:1.04}
h1 {font-size: clamp(39px, 6vw, 84px);margin-bottom:30px;letter-spacing:3px;opacity:.9;font-weight:700}
h2 {font-size: clamp(32px, 6vw, 54px);margin-bottom:25px;/*line-height:clamp(30px, 6vw, 74px)*/opacity:.9}
h2 strong{font-weight:500}
h3{font-size:clamp(24px, 5vw, 30px);margin:15px 0}
h4{font-size:clamp(19px, 5vw, 20px);margin:15px 0;font-weight:300;letter-spacing:1px;opacity:.9}
.banner-text{max-width:500px;margin-bottom:50px}
a, a:focus, a:hover, a:visited {text-decoration:none;color: inherit;}
img {max-width: 100%;height: auto;}
input, select, textarea {font-family: "Outfit", sans-serif;font-weight:200}
*:focus {outline: none;}
.has-text-align-center, .aligncenter {text-align:center;}
iframe {max-width: 100%;}
figure {margin:0;}
.kb-form {-webkit-align-items: normal!important;align-items: normal!important;}
.alignright, .has-text-align-right {text-align:right}
