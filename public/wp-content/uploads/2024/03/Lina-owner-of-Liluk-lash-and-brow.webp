.glass2 > .kt-inside-inner-col{background: rgba(83,83,83,0.2);backdrop-filter: blur(5px);-webkit-backdrop-filter: blur(5px);}
.glass2:hover > .kt-inside-inner-col{backdrop-filter: blur(16px);-webkit-backdrop-filter: blur(16px);}
	
