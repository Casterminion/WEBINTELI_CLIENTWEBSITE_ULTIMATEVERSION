.img-appear-section2>.kt-inside-inner-col{position:relative;overflow:hidden;}
.img-appear-section2>.kt-inside-inner-col::before{content:"";position:absolute;inset:-10%;background-image:inherit;background-size:cover;background-position:center center;background-repeat:no-repeat;transform:translate3d(0,var(--parallaxY,0),0) scale(1.25);transform-origin:center center;will-change:transform;pointer-events:none;}

.img-appear-section3>.kt-inside-inner-col{position:relative;overflow:hidden;}
.img-appear-section3>.kt-inside-inner-col::before{content:"";position:absolute;inset:-1%;background-image:inherit;background-size:cover;background-position:center center;background-repeat:no-repeat;transform:translate3d(0,var(--parallaxY,0),0) scale(1.25);transform-origin:center center;will-change:transform;pointer-events:none;}
	
/* text underline on hover required */
.fx-underline h3{--ul:0,0,0;--ul-a:.4}
.fx-underline h3 .fx-line{box-decoration-break:clone;-webkit-box-decoration-break:clone;background-image:linear-gradient(rgba(var(--ul),var(--ul-a)),rgba(var(--ul),var(--ul-a)));background-repeat:no-repeat;background-position:0 100%;background-size:0 2px;padding-bottom:0.12em}

