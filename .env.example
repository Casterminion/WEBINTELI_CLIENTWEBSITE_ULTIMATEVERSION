# Optional: label for admin “new release” banner (defaults to Vercel git short SHA, else dev-<package version>)
# NEXT_PUBLIC_APP_RELEASE=

# Supabase (required for intake form submissions)
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only: used by the intake API route to insert submissions (bypasses RLS).
# Never expose this key in the client (do not use NEXT_PUBLIC_ prefix).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Web push VAPID keys (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY=your-vapid-public-key
WEB_PUSH_PUBLIC_KEY=your-vapid-public-key
WEB_PUSH_PRIVATE_KEY=your-vapid-private-key

# Optional: shared secret for Supabase webhook → notify-new-lead API
PUSH_WEBHOOK_SECRET=some-long-random-string

# Optional: office / Coolify PDF worker (same secret as worker WORKER_SECRET).
# If unset, PDF is rendered inside the Next.js API route.
# PDF_WORKER_URL=https://your-worker.example.com
# PDF_WORKER_SECRET=long-random-string-matching-worker

# For production (e.g. Netlify, Vercel): add the same variables in
# environment settings. Use your real Supabase URL, anon key, and service role key.
