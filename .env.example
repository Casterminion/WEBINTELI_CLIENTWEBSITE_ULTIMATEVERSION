# Supabase (required for intake form submissions)
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# For production (e.g. Netlify): add the same variables in
# Site settings → Environment variables. Use your real Supabase URL and anon key.
